---
import WorksGallery from '@/components/WorksGallery.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'
import { getPostsByTags, getTagSupportedLangs } from '@/utils/content'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const currentLang = getLangFromLocale(Astro.currentLocale)
// 根据语言选择正确的标签（作品集和数字绘画）
const tags = currentLang === 'zh' || currentLang === 'zh-tw'
  ? ['作品集', '数字绘画']
  : ['Portfolio', 'Digital Painting']
const posts = await getPostsByTags(tags, currentLang)
const supportedLangs = await getTagSupportedLangs(tags[0])
---

<Layout supportedLangs={supportedLangs}>
  <!-- Decorative Line -->
  <div class="uno-decorative-line" />

  <!-- Works Gallery -->
  <div class="mt-6 lg:mt-10.5">
    <WorksGallery
      posts={posts}
      lang={currentLang}
    />
  </div>
</Layout>
