---
import type { ImageMetadata } from 'astro'
import type { Language } from '@/i18n/config'
import type { Post } from '@/types'
import { getPostPath } from '@/i18n/path'

interface Props {
  posts: Post[]
  lang: Language
}

const { posts, lang } = Astro.props

// 动态导入 src/content/posts/_images 目录下的所有图片
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/_images/**/*.{jpeg,jpg,png,gif,webp}',
  { eager: true },
)

// 提取文章的第一张图片
async function getThumbnail(post: Post): Promise<{ type: 'image', src: string } | null> {
  const content = post.body || ''

  // 检查是否有第一张图片
  const imageMatch = content.match(/!\[.*?\]\((.*?\.(?:webp|jpg|jpeg|png|gif))\)/)
  if (imageMatch) {
    const imagePath = imageMatch[1]

    // 处理相对路径，转换为绝对路径
    if (imagePath.startsWith('./_images/') || imagePath.startsWith('../_images/')) {
      // 解码 URL 编码的字符（如%20）
      const decodedPath = decodeURIComponent(imagePath)
      // 正确处理各种相对路径情况，保留子目录结构
      const imageName = decodedPath.replace(/^(\.\.?\/)?_images\//, '')
      const absolutePath = `/src/content/posts/_images/${imageName}`

      // 查找对应的图片模块
      const imageImporter = imagesGlob[absolutePath]
      if (imageImporter) {
        const imageMetadata = imageImporter.default
        // 直接返回图片路径，Astro 会自动处理优化
        return { type: 'image', src: imageMetadata.src }
      }
    }

    // 如果是外部链接，直接使用
    if (imagePath.startsWith('http')) {
      return { type: 'image', src: imagePath }
    }

    // 其他情况返回原路径
    return { type: 'image', src: imagePath }
  }

  return null
}

// 获取文章描述
function getDescription(post: Post): string {
  return post.data.description || '暂无描述'
}

// 获取所有分类标签
function getCategories(posts: Post[]): string[] {
  const categories = new Set<string>()
  posts.forEach((post) => {
    if (post.data.tags && post.data.tags.length > 0) {
      post.data.tags.forEach((tag: string) => categories.add(tag))
    }
  })
  return Array.from(categories).sort()
}
---

<div class="works-gallery">
  <!-- 分类标签 -->
  <div class="category-tags">
    <div class="no-heti flex flex-wrap gap-x-3 gap-y-3.2">
      <button class="category-tag active" data-category="all">
        <span class="category-text">{lang === 'zh' ? '全部' : lang === 'zh-tw' ? '全部' : 'All'}</span>
      </button>
      {getCategories(posts).map(category => (
        <button class="category-tag" data-category={category}>
          <span class="category-text">{category}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- 相册列表 -->
  <div class="album-list">
    {await Promise.all(posts.map(async (post) => {
      const slug = post.data.abbrlink || post.id
      const thumbnail = await getThumbnail(post)
      const description = getDescription(post)
      const postCategories = post.data.tags || []

      return (
        <div class="album-item" data-categories={postCategories.join(',')}>
          <a
            href={getPostPath(slug, lang)}
            class="album-link"
            transition:name={`post-${slug}${lang ? `-${lang}` : ''}`}
            data-disable-theme-toggle-transition
          >
            <!-- 大图区域 -->
            <div class="album-thumbnail">
              {thumbnail
? (
                <img
                  src={thumbnail.src}
                  alt={post.data.title}
                  loading="lazy"
                  class="thumbnail-image"
                />
              )
: (
                <div class="thumbnail-placeholder">
                  <span class="placeholder-text">{lang === 'zh' ? '暂无图片' : 'No Image'}</span>
                </div>
              )}
            </div>

            <!-- 内容区域 -->
            <div class="album-info">
              <h3 class="album-title">{post.data.title}</h3>
              <p class="album-description">{description}</p>
              <div class="album-meta">
                <span class="album-date">
                  {post.data.published.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}
                </span>
                {postCategories.length > 0 && (
                  <div class="album-tags">
                    {postCategories.map((tag: string) => (
                      <span class="album-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        </div>
      )
    }))}
  </div>

  <!-- 分类筛选脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const categoryTags = document.querySelectorAll('.category-tag')
      const albumItems = document.querySelectorAll('.album-item')

      categoryTags.forEach((tag) => {
        tag.addEventListener('click', (event) => {
          const target = event.target as HTMLElement

          // 移除所有标签的激活状态
          categoryTags.forEach(t => t.classList.remove('active'))

          // 添加当前标签的激活状态
          target.classList.add('active')

          const selectedCategory = target.dataset.category || 'all'

          // 筛选作品
          albumItems.forEach((item) => {
            const itemElement = item as HTMLElement
            if (selectedCategory === 'all') {
              itemElement.style.display = 'block'
            }
            else {
              const categories = itemElement.dataset.categories?.split(',') || []
              if (categories.includes(selectedCategory)) {
                itemElement.style.display = 'block'
              }
              else {
                itemElement.style.display = 'none'
              }
            }
          })
        })
      })
    })
  </script>
</div>

<style>
.works-gallery {
  max-width: 1000px;
  margin: 0 auto;
  padding: 1.5rem 0;
}

@media (min-width: 1024px) {
  .works-gallery {
    padding: 2rem 0;
  }
}

/* 分类标签样式 - 精致线框设计 */
.category-tags {
  margin-bottom: 3rem;
  margin-top: -0.5rem;
}

.category-tags .no-heti {
  justify-content: flex-start;
  gap: 0.75rem;
}

.category-tag {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.15);
  border-radius: 6px;
  padding: 0.5rem 1.25rem;
  background: transparent;
  color: oklch(var(--un-preset-theme-colors-secondary) / 0.8);
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 2.25rem;
  letter-spacing: 0.01em;
}

.category-text {
  transform: translateY(1px);
}

.category-tag:hover {
  border-color: oklch(var(--un-preset-theme-colors-primary) / 0.3);
  color: oklch(var(--un-preset-theme-colors-primary));
  transform: translateY(-1px);
}

.category-tag.active {
  border-color: oklch(var(--un-preset-theme-colors-primary) / 0.4);
  color: oklch(var(--un-preset-theme-colors-primary));
  background: oklch(var(--un-preset-theme-colors-primary) / 0.08);
}

/* 相册列表样式 - 单列大图布局 */
.album-list {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.album-item {
  width: 100%;
}

.album-link {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.3s ease;
  border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.15);
  border-radius: 8px;
  overflow: hidden;
  background: oklch(var(--un-preset-theme-colors-background) / 0.5);
}

.album-link:hover {
  transform: translateY(-4px);
  border-color: oklch(var(--un-preset-theme-colors-primary) / 0.3);
}

/* 大图区域 - 与按钮对齐 */
.album-thumbnail {
  width: 100%;
  height: 400px;
  overflow: hidden;
  position: relative;
  background: oklch(var(--un-preset-theme-colors-background) / 0.3);
  border-bottom: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.15);
}

.thumbnail-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(100%) contrast(0.55) brightness(1.05) sepia(15%);
  transition: all 0.6s ease;
}

.album-link:hover .thumbnail-image {
  filter: grayscale(0%) contrast(1) brightness(1) sepia(0%);
  transform: scale(1.03);
}

.thumbnail-placeholder {
  width: 100%;
  height: 100%;
  background: oklch(var(--un-preset-theme-colors-background) / 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: oklch(var(--un-preset-theme-colors-secondary) / 0.6);
}

.placeholder-text {
  font-size: 1rem;
  opacity: 0.6;
}

/* 内容区域 */
.album-info {
  padding: 1.5rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.album-title {
  margin: 0;
  font-size: 1.4rem;
  font-weight: 600;
  line-height: 1.35;
  color: var(--text-color);
  letter-spacing: -0.01em;
}

.album-description {
  margin: 0;
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 元信息区域 */
.album-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.8rem;
  color: oklch(var(--un-preset-theme-colors-secondary) / 0.5);
  padding-top: 0.75rem;
  border-top: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.15);
  margin-top: 0.5rem;
}

.album-date {
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}

/* 标签样式 */
.album-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.album-tag {
  border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.15);
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  font-size: 0.75rem;
  color: oklch(var(--un-preset-theme-colors-secondary) / 0.6);
  transition: all 0.2s ease;
  background: transparent;
}

.album-tag:hover {
  border-color: oklch(var(--un-preset-theme-colors-primary) / 0.3);
  color: oklch(var(--un-preset-theme-colors-primary));
}

/* 分割线已移除，改用卡片间隔 */
.album-divider {
  display: none;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .works-gallery {
    padding: 1.5rem 0;
  }
  .album-thumbnail {
    height: 300px;
  }
  .album-info {
    padding: 1.25rem 1.5rem;
  }
  .album-title {
    font-size: 1.25rem;
  }
  .category-tags {
    margin-bottom: 2rem;
  }
  .category-tag {
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
  }
}

@media (max-width: 480px) {
  .album-thumbnail {
    height: 240px;
  }
  .album-title {
    font-size: 1.15rem;
  }
  .album-description {
    font-size: 0.9rem;
  }
  .album-info {
    padding: 1rem 1.25rem;
  }
  .category-tag {
    padding: 0.4rem 0.875rem;
    font-size: 0.8rem;
  }
}
</style>
