---
import type { Language } from '@/i18n/config'
import { getTagPath } from '@/i18n/path'

interface Props {
  tags: string[]
  currentTag?: string
  lang: Language
}

const { tags, currentTag = '', lang } = Astro.props
---

<div class="no-heti mb-10.5 flex flex-wrap gap-x-3 gap-y-3.2">
  {tags.map(tag => (
    <a
      href={getTagPath(tag, lang)}
      class:list={[
        'tag-item',
        currentTag === tag ? 'active' : '',
      ]}
    >
      <span class="tag-text">{tag}</span>
    </a>
  ))}
</div>
