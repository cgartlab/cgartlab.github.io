---
import type { ImageMetadata } from 'astro'
import type { Language } from '@/i18n/config'
import type { Post } from '@/types'
import { getPostPath } from '@/i18n/path'

interface Props {
  posts: Post[]
  lang: Language
}

const { posts, lang } = Astro.props

// 动态导入 src/content/posts/_images 目录下的所有图片
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/_images/**/*.{jpeg,jpg,png,gif,webp}',
  { eager: true },
)

// 提取文章的第一张图片
async function getThumbnail(post: Post): Promise<{ type: 'image', src: string } | null> {
  const content = post.body || ''

  // 检查是否有第一张图片
  const imageMatch = content.match(/!\[.*?\]\((.*?\.(?:webp|jpg|jpeg|png|gif))\)/)
  if (imageMatch) {
    const imagePath = imageMatch[1]

    // 处理相对路径，转换为绝对路径
    if (imagePath.startsWith('./_images/') || imagePath.startsWith('../_images/')) {
      // 解码 URL 编码的字符（如%20）
      const decodedPath = decodeURIComponent(imagePath)
      // 更安全地获取文件名，处理各种路径情况
      const pathParts = decodedPath.split('/')
      const imageName = pathParts[pathParts.length - 1]
      const absolutePath = `/src/content/posts/_images/${imageName}`

      // 查找对应的图片模块
      const imageImporter = imagesGlob[absolutePath]
      if (imageImporter) {
        const imageMetadata = imageImporter.default
        // 直接返回图片路径，Astro 会自动处理优化
        return { type: 'image', src: imageMetadata.src }
      }
    }

    // 如果是外部链接，直接使用
    if (imagePath.startsWith('http')) {
      return { type: 'image', src: imagePath }
    }

    // 其他情况返回原路径
    return { type: 'image', src: imagePath }
  }

  return null
}

// 获取文章描述
function getDescription(post: Post): string {
  return post.data.description || ''
}
---

<div class="weekly-gallery">
  <!-- 周刊列表 -->
  <div class="weekly-list">
    {await Promise.all(posts.map(async (post) => {
      const slug = post.data.abbrlink || post.id
      const thumbnail = await getThumbnail(post)
      const description = getDescription(post)

      return (
        <div class="weekly-item">
          <a
            href={getPostPath(slug, lang)}
            class="weekly-link"
            transition:name={`post-${slug}${lang ? `-${lang}` : ''}`}
            data-disable-theme-toggle-transition
          >
            <!-- 封面图区域 -->
            <div class="weekly-thumbnail">
              {thumbnail
                ? (
                  <img
                    src={thumbnail.src}
                    alt={post.data.title}
                    loading="lazy"
                    class="thumbnail-image"
                  />
                )
                : (
                  <div class="thumbnail-placeholder">
                    <span class="placeholder-text">{lang === 'zh' ? '周刊' : 'Weekly'}</span>
                  </div>
                )}
            </div>

            <!-- 内容区域 -->
            <div class="weekly-info">
              <h3 class="weekly-title">{post.data.title}</h3>
              {description && <p class="weekly-description">{description}</p>}
              <div class="weekly-meta">
                <span class="weekly-date">
                  {post.data.published.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US')}
                </span>
              </div>
            </div>
          </a>
        </div>
      )
    }))}
  </div>
</div>

<style>
.weekly-gallery {
  max-width: 1000px;
  margin: 0 auto;
  padding: 1.5rem 0;
}

@media (min-width: 1024px) {
  .weekly-gallery {
    padding: 2rem 0;
  }
}

/* 周刊列表样式 - 网格布局 */
.weekly-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}

.weekly-item {
  width: 100%;
}

.weekly-link {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.3s ease;
  border: 1px solid var(--border-color, #e5e7eb);
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-secondary);
}

.weekly-link:hover {
  transform: translateY(-4px);
  border-color: rgba(0, 0, 0, 0.5);
}

/* 封面图区域 */
.weekly-thumbnail {
  width: 100%;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  position: relative;
  background: var(--bg-tertiary);
  border-bottom: 1px solid var(--border-color, #e5e7eb);
}

.thumbnail-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(100%) contrast(0.55) brightness(1.05) sepia(15%);
  transition: all 0.6s ease;
}

.weekly-link:hover .thumbnail-image {
  filter: grayscale(0%) contrast(1) brightness(1) sepia(0%);
  transform: scale(1.03);
}

.thumbnail-placeholder {
  width: 100%;
  height: 100%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
}

.placeholder-text {
  font-size: 1.25rem;
  font-weight: 600;
  opacity: 0.4;
  letter-spacing: 0.1em;
}

/* 内容区域 */
.weekly-info {
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.weekly-title {
  margin: 0;
  font-size: 1.15rem;
  font-weight: 600;
  line-height: 1.4;
  color: var(--text-color);
  letter-spacing: -0.01em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.weekly-description {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 元信息区域 */
.weekly-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.8rem;
  color: var(--text-tertiary);
  padding-top: 0.75rem;
  border-top: 1px solid var(--border-color, #e5e7eb);
  margin-top: 0.5rem;
}

.weekly-date {
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .weekly-gallery {
    padding: 1.5rem 0;
  }
  .weekly-list {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .weekly-thumbnail {
    aspect-ratio: 16 / 9;
  }
  .weekly-info {
    padding: 1rem 1.25rem;
  }
  .weekly-title {
    font-size: 1.1rem;
  }
}

@media (max-width: 480px) {
  .weekly-thumbnail {
    aspect-ratio: 16 / 10;
  }
  .weekly-title {
    font-size: 1rem;
  }
  .weekly-description {
    font-size: 0.85rem;
  }
  .placeholder-text {
    font-size: 1rem;
  }
}
</style>
