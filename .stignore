# Syncthing 忽略文件 - CGArtLab 知识库
# 所有设备必须使用相同的忽略规则，避免删除冲突

# Syncthing 元数据（显式允许同步，确保跨设备一致性）
!.stfolder/
.stversions/
.syncthing-*
*.sync-conflict-*

# Git 元数据
(?d).git/

# 构建与缓存（每设备独立构建）
(?d).cache/
(?d).temp/
(?d).output/
(?d).astro/
(?d)dist/
(?d)node_modules/

# 日志
*.log

# 环境配置（每设备独立配置）
.env
.env.*
!.env.example

# 系统文件
.DS_Store*
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# 编辑器（每设备独立配置）
(?d).idea/
(?d).vscode/
*.swp
*.swo

# 临时文件
.trash/
*.tmp
*.temp
*.bak
*.backup

# 锁文件（每设备独立生成）
package-lock.json
yarn.lock
pnpm-lock.yaml

# 部署与测试
.vercel/
.netlify/
.devcontainer/
coverage/

# Obsidian 配置
.obsidian/workspace*.json
.obsidian/app.json
.obsidian/appearance.json
.obsidian/hotkeys.json
.obsidian/graph.json
.obsidian/page-preview.json
(?d).obsidian/.copilot-index/
(?d).obsidian/.trash/

# 允许同步 Obsidian 共享配置
!.obsidian/plugins/
!.obsidian/themes/
!.obsidian/core-plugins.json
!.obsidian/community-plugins.json
!.obsidian/templates.json

# 项目特定
src/assets/lqip-map.json
